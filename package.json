{
  "name": "@nxtedition/re2",
  "version": "1.0.13",
  "description": "Fast RE2 partial matching for Node.js",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "benchmark.js",
    "binding.cc",
    "binding.gyp",
    "lib",
    "native",
    "prebuilds",
    "THIRD_PARTY.md",
    "vendor/abseil-cpp/absl",
    "vendor/abseil-cpp/LICENSE",
    "vendor/re2/re2",
    "vendor/re2/util/rune.cc",
    "vendor/re2/util/strutil.cc",
    "vendor/re2/util/strutil.h",
    "vendor/re2/util/utf.h",
    "vendor/re2/LICENSE",
    "!vendor/**/testdata/**",
    "!vendor/**/testing/**",
    "!vendor/**/*_test.c",
    "!vendor/**/*_test.cc",
    "!vendor/**/*_test.h",
    "!vendor/**/test_*.c",
    "!vendor/**/test_*.cc",
    "!vendor/**/test_*.h",
    "!vendor/**/*_benchmark.cc",
    "!vendor/**/*_benchmark.h",
    "!vendor/**/benchmarks.cc",
    "!vendor/**/*_test*.*",
    "!vendor/**/*_testing*.*",
    "!vendor/**/*_benchmark*.*",
    "!vendor/**/*_benchmarks*.*",
    "!vendor/**/CMakeLists.txt",
    "!vendor/**/BUILD",
    "!vendor/**/BUILD.bazel"
  ],
  "engines": {
    "node": ">=26"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nxtedition/node-re2.git"
  },
  "bugs": {
    "url": "https://github.com/nxtedition/node-re2/issues"
  },
  "homepage": "https://github.com/nxtedition/node-re2#readme",
  "dependencies": {
    "node-gyp": "^13.0.1",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "prebuildify": "^6.0.1",
    "rimraf": "^6.1.3",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "benchmark": "npm run build:ts --silent && node benchmark.js",
    "benchmark:prebuild": "npm run build:ts --silent && PREBUILDS_ONLY=1 node benchmark.js",
    "install": "node-gyp-build",
    "build": "npm run build:ts && npm run build:native",
    "build:native": "node-gyp rebuild --jobs=max",
    "build:ts": "rimraf lib && tsc -p tsconfig.build.json",
    "pretest": "npm run build",
    "prepare": "npm run build:ts",
    "test": "node --test && npm run test:types",
    "test:prebuild": "npm run build:ts && PREBUILDS_ONLY=1 node --test && npm run test:types",
    "test:types": "tsc -p type-tests/tsconfig.json",
    "verify:prebuilds": "node scripts/verify-prebuilds.mjs",
    "rebuild": "npm_config_build_from_source=true node-gyp-build",
    "release": "./release.sh"
  },
  "gypfile": true,
  "license": "MIT"
}
